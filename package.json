{
  "name": "nextjs-modernization",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "tsc": "bun ./node_modules/@typescript/native/bin/tsc",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "test": "playwright test",
    "test:unit": "bun run scripts/test-unit.ts",
    "test:e2e": "playwright test",
    "test:all": "bun run test:unit && bun run test:e2e",
    "newsletter:send-due": "bun run scripts/send-due-newsletters.ts",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "db:studio": "bunx drizzle-kit studio --config drizzle.config.ts",
    "db:migrate": "bun run scripts/db/migrate.ts",
    "db:migrate:dev": "bun run scripts/db/migrate.ts --env=dev",
    "db:migrate:staging": "bun run scripts/db/migrate.ts --env=staging",
    "db:migrate:prod": "bun run scripts/db/migrate.ts --env=prod",
    "db:check:migrations": "bun run scripts/db/check-schema-migration-sync.ts",
    "db:cleanup-test-data": "bun run scripts/db/cleanup-test-data.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.111.0",
    "@aws-sdk/client-s3": "3.1086.0",
    "@paralleldrive/cuid2": "3.3.0",
    "@smithy/core": "3.29.3",
    "@tailwindcss/typography": "0.5.20",
    "cheerio": "1.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "gray-matter": "4.0.3",
    "next": "16.2.10",
    "next-mdx-remote": "6.0.0",
    "next-themes": "0.4.6",
    "postgres": "3.4.9",
    "posthog-js": "1.399.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "20.19.43",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native": "npm:typescript@7.0.2",
    "bun-types": "1.3.14",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "overrides": {
    "flatted": "3.4.2",
    "postcss": "8.5.19",
    "undici": "7.28.0",
    "yaml": "2.9.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
